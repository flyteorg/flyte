{
  "name": "@union/workflowsv2",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "node ./scripts/launchDev.js",
    "dev:local": "cross-env NODE_OPTIONS='--inspect' next dev",
    "dev:next": "cross-env NODE_OPTIONS='--inspect' next dev --experimental-https --experimental-https-key ./scripts/certificate/server.key --experimental-https-cert ./scripts/certificate/server.crt -H $NEXT_PUBLIC_ADMIN_DOMAIN",
    "dev:ci": "cross-env NODE_OPTIONS='--inspect' next dev --experimental-https --experimental-https-key ./scripts/certificate/server.key --experimental-https-cert ./scripts/certificate/server.crt -H $DEV_HOST -p ${PORT:-8080}",
    "build:prod": "NODE_ENV=production pnpm run build --webpack && pnpm run postbuild:monaco",
    "postbuild:monaco": "rm -rf public/monaco && mkdir -p public/monaco && cp -R node_modules/monaco-editor/min/vs public/monaco/vs",
    "serve:prod": "pnpm build:prod && PORT=8080 pnpm start",
    "gen:ssl": "./scripts/generate_ssl.sh",
    "build": "next build --webpack",
    "start": "next start",
    "lint": "eslint 'src/**/*.{js,jsx,ts,tsx}'",
    "typecheck": "tsc -p tsconfig.typecheck.json",
    "storybook": "storybook dev -p 6006",
    "build-storybook": "storybook build",
    "serve-storybook": "serve storybook-static -l 6006",
    "chromatic": "chromatic --exit-zero-on-changes",
    "prettier": "prettier . --write --ignore-unknown",
    "test:unit": "vitest --no-watch",
    "test:unit:watch": "vitest",
    "test:e2e": "pnpm exec playwright test",
    "test:e2e:ui": "pnpm exec playwright test --ui",
    "postMessageToSlack": "node ./scripts/postMessageToSlack.mjs"
  },
  "browserslist": "defaults, not ie <= 11",
  "dependencies": {
    "@bufbuild/protobuf": "^2.2.5",
    "@codemirror/lang-python": "^6.1.7",
    "@connectrpc/connect": "^2.0.2",
    "@connectrpc/connect-query": "^2.0.1",
    "@connectrpc/connect-web": "^2.0.2",
    "@floating-ui/react": "^0.27.12",
    "@grafana/faro-react": "^2.0.0-beta",
    "@grafana/faro-web-sdk": "^2.0.0-beta",
    "@grafana/faro-web-tracing": "^2.0.0-beta",
    "@grafana/faro-webpack-plugin": "^0.8.1",
    "@headlessui/react": "^2.1.0",
    "@heroicons/react": "^2.2.0",
    "@llm-ui/code": "^0.13.3",
    "@llm-ui/markdown": "^0.13.3",
    "@llm-ui/react": "^0.13.3",
    "@monaco-editor/react": "4.8.0-rc.3",
