    "import-in-the-middle": "^2.0.1",
    "iso8601-duration": "^2.1.3",
    "js-untar": "^2.0.0",
    "lodash": "^4.17.21",
    "monaco-editor": "0.55.0-rc",
    "motion": "^12.23.3",
    "msgpackr": "^1.11.4",
    "next": "^16.0.10",
    "next-runtime-env": "^3.3.0",
