    {
      "type": "text",
      "id": "nd_d5_a7_label",
      "x": 845,
      "y": 3530,
      "width": 24.98980712890625,
      "height": 16.341437267497184,
      "text": "SQL",
      "originalText": "SQL",
      "fontSize": 13.073149813997748,
      "fontFamily": 1,
      "textAlign": "center",
