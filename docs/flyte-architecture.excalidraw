    },
    {
      "type": "text",
      "id": "nd_d3_payload_update",
      "x": 638.4295654296875,
      "y": 2481.015625,
      "width": 520,
      "height": 162.5,
      "text": "UpdateActionStatusRequest  (on every phase change)\n  action_id: { run, name, org, project, domain }\n  status: ActionStatus {\n    phase:  QUEUED | RUNNING | SUCCEEDED |\n            FAILED | ABORTED | ...\n    attempts: <retry count>\n    cache_status: { HIT | MISS | POPULATED | ... }\n  }\n\n",
