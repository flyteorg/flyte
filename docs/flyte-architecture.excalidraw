    {
      "type": "text",
      "id": "nd_d3_payload_record",
      "x": 70.4295654296875,
      "y": 2481.015625,
      "width": 540,
      "height": 180,
      "text": "RecordActionRequest  (on ADDED, deduped via bloom filter)\n  action_id: { run, name, org, project, domain }\n  parent: <parent action name>          // empty for root\n  input_uri: s3://.../inputs.pb\n  group: <action group>\n  spec: oneof {\n    task: TaskAction {\n      id: { project, domain, name, version }\n      spec.task_template, spec.short_name\n    }\n    trace: TraceAction { ... }\n  }",
      "originalText": "RecordActionRequest  (on ADDED, deduped via bloom filter)\n  action_id: { run, name, org, project, domain }\n  parent: <parent action name>          // empty for root\n  input_uri: s3://.../inputs.pb\n  group: <action group>\n  spec: oneof {\n    task: TaskAction {\n      id: { project, domain, name, version }\n      spec.task_template, spec.short_name\n    }\n    trace: TraceAction { ... }\n  }",
      "fontSize": 13,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "lineHeight": 1.25,
      "autoResize": false,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 1,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 92003,
