      "updated": 1,
      "link": null,
      "locked": false,
      "fontSize": 13,
      "fontFamily": 1,
      "text": "Watches TaskAction CRDs via K8s informers (no polling).\nHorizontally scaled via leader election; each replica owns a shard of CRDs.\nPlugins (Pod, Spark, Ray, Dask, ...) translate TaskAction \u2192 native K8s resources.",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Watches TaskAction CRDs via K8s informers (no polling).\nHorizontally scaled via leader election; each replica owns a shard of CRDs.\nPlugins (Pod, Spark, Ray, Dask, ...) translate TaskAction \u2192 native K8s resources.",
      "autoResize": true,
      "lineHeight": 1.25
    },
