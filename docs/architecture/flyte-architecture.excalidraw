      "link": null,
      "locked": false,
      "fontSize": 13,
      "fontFamily": 1,
      "text": "Writes one TaskAction CRD per action; partitioned by action ID for locality.\nUnified service replaces legacy QueueService + StateService (feature-flagged).",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Writes one TaskAction CRD per action; partitioned by action ID for locality.\nUnified service replaces legacy QueueService + StateService (feature-flagged).",
      "autoResize": true,
      "lineHeight": 1.25
    },
    {
      "id": "scaling-note-2-title",
