      "locked": false,
      "fontSize": 13,
      "fontFamily": 1,
      "text": "Stateless; issues signed URLs so pods and SDK read/write Object Storage directly \u2014\nno data passes through the service (keeps the hot path off the control plane).",
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": null,
      "originalText": "Stateless; issues signed URLs so pods and SDK read/write Object Storage directly \u2014\nno data passes through the service (keeps the hot path off the control plane).",
      "autoResize": true,
      "lineHeight": 1.25
    },
