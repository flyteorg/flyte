FROM --platform=${BUILDPLATFORM} golang:1.26.3-bookworm AS flytebuilder

ARG TARGETARCH
ENV GOARCH="${TARGETARCH}"
ENV GOOS=linux
ENV CGO_ENABLED=0

WORKDIR /flyteorg/build

# flytecopilot builds out of the single root module, so copy the same set of
# module directories the main image uses to keep the build self-contained.
COPY dataproxy dataproxy
COPY executor executor
COPY flytecopilot flytecopilot
COPY flyteidl2 flyteidl2
COPY flyteplugins flyteplugins
COPY flytestdlib flytestdlib
COPY gen/go gen/go
COPY actions actions
COPY app app
COPY events events
COPY runs runs
COPY cache_service cache_service
COPY secret secret

COPY go.mod go.sum ./
RUN go mod download
COPY manager manager
RUN --mount=type=cache,target=/root/.cache/go-build --mount=type=cache,target=/root/go/pkg/mod \
    go build -v -o dist/flyte-copilot ./flytecopilot


FROM debian:bookworm-slim

ARG FLYTE_VERSION
ENV FLYTE_VERSION="${FLYTE_VERSION}"

ENV DEBCONF_NONINTERACTIVE_SEEN=true
ENV DEBIAN_FRONTEND=noninteractive

RUN apt-get update && apt-get install --no-install-recommends --yes \
        ca-certificates \
    && rm -rf /var/lib/apt/lists/*

# flyteplugins invokes copilot as `/bin/flyte-copilot` (see
# flytek8s.CopilotCommandArgs), so install the binary at that exact path.
COPY --from=flytebuilder /flyteorg/build/dist/flyte-copilot /bin/flyte-copilot

CMD ["flyte-copilot"]
